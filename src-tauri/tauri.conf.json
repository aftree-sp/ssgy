{
  "productName": "爆闪狗眼",
  "version": "1.0.0",
  "identifier": "com.aftreeps.ssgy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "title": "爆闪狗眼",
      "width": 390,
      "height": 844,
      "resizable": false,
      "fullscreen": false
    }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "iOS": {
      "infoPlist": {
        "NSCameraUsageDescription": "需要使用相机闪光灯来控制闪光"
      }
    }
  }
}
